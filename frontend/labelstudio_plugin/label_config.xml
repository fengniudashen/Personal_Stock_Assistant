<!-- VibeSing 高音觉醒 - Label Studio 标注配置 v2.0
     标签体系：主标签(发声机制/互斥) + 辅标签(共鸣技术/可叠加) + 质量旗标
     设计原则：机制与色彩正交，降低标注混淆 -->
<View>
  <Style>
    .section-primary {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white; padding: 14px; margin: 20px 0 12px 0;
      border-radius: 10px; font-weight: bold; font-size: 16px;
      box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    }
    .section-secondary {
      background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
      color: white; padding: 14px; margin: 20px 0 12px 0;
      border-radius: 10px; font-weight: bold; font-size: 16px;
    }
    .section-quality {
      background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
      color: white; padding: 14px; margin: 20px 0 12px 0;
      border-radius: 10px; font-weight: bold; font-size: 16px;
    }
    .ai-assist {
      background: linear-gradient(135deg, #fff5e1 0%, #ffe4b5 100%);
      padding: 16px; margin: 16px 0; border-radius: 10px;
      border-left: 5px solid #ffa500;
    }
    .distinction-box {
      background: #fef3c7; border: 2px solid #f59e0b;
      padding: 12px; margin: 12px 0; border-radius: 8px;
      font-size: 13px; line-height: 1.7;
    }
    .hotkey-guide {
      background: linear-gradient(135deg, #e0f2fe 0%, #dbeafe 100%);
      padding: 14px; margin: 20px 0; border-radius: 10px;
      border-left: 4px solid #0284c7;
    }
  </Style>

  <Header value="🎤 VibeSing「高音觉醒」标注系统 v2.0"/>
  <Audio name="audio" value="$audio_url" zoom="true" speed="true" hotkey="space"/>

  <!-- AI辅助信息 -->
  <View className="ai-assist">
    <Header value="🤖 AI分析结果" size="4"/>
    <Text name="ai_primary" value="$ai_label"/>
    <Text name="ai_conf" value="$ai_confidence"/>
    <Text name="ai_secondary" value="$ai_secondary"/>
    <View style="margin-top:8px; padding-top:8px; border-top:1px solid #fbbf24;">
      <Text name="pitch_info_display" value="$pitch_info"/>
      <Text name="acoustic_hint" value="$acoustic_hint"/>
      <Text name="asr_display" value="$asr_transcript"/>
    </View>
  </View>

  <!-- 第一部分：主标签（发声机制，单选必填）-->
  <View className="section-primary">
    📌 第一步：选择发声机制（单选，必填）
  </View>
  <Text value="💡 主标签=声带如何振动。流程: 是否有效歌唱→问题优先→机制归类"/>

  <Choices name="primary_label" toName="audio" choice="single-radio" required="true">
    <Choice value="StrongMix" hotkey="1"
            html="&lt;div style='background:#d1fae5;padding:10px;border-radius:8px;border:2px solid #10b981;margin:4px 0'&gt;&lt;b&gt;💪 1 强混声 StrongMix&lt;/b&gt;&lt;br/&gt;&lt;small&gt;闭合强·支撑足·同音高可提升响度·上行不虚·低中高频均衡&lt;/small&gt;&lt;br/&gt;&lt;small style='color:#059669'&gt;例: 信乐团《死了都要爱》副歌&lt;/small&gt;&lt;/div&gt;"/>
    <Choice value="LightMix" hotkey="2"
            html="&lt;div style='background:#fef3c7;padding:10px;border-radius:8px;border:2px solid #f59e0b;margin:4px 0'&gt;&lt;b&gt;🌸 2 弱混声 LightMix&lt;/b&gt;&lt;br/&gt;&lt;small&gt;轻盈柔和·连接顺滑·低频实体感较弱·高频明显&lt;/small&gt;&lt;br/&gt;&lt;small style='color:#059669'&gt;例: 李健《贝加尔湖畔》&lt;/small&gt;&lt;/div&gt;"/>
    <Choice value="Falsetto" hotkey="3"
            html="&lt;div style='background:#fae8ff;padding:10px;border-radius:8px;border:2px solid #c084fc;margin:4px 0'&gt;&lt;b&gt;🎈 3 假声 Falsetto&lt;/b&gt;&lt;br/&gt;&lt;small&gt;声带边缘振动·轻飘空灵·力量感弱·谐波稀疏&lt;/small&gt;&lt;br/&gt;&lt;small style='color:#059669'&gt;例: 周杰伦《暗号》&lt;/small&gt;&lt;/div&gt;"/>
    <Choice value="Chest" hotkey="4"
            html="&lt;div style='background:#dbeafe;padding:10px;border-radius:8px;border:2px solid #60a5fa;margin:4px 0'&gt;&lt;b&gt;🗣️ 4 胸声 Chest&lt;/b&gt;&lt;br/&gt;&lt;small&gt;中低音自然发声·厚实沉稳（主要小于C4区域）&lt;/small&gt;&lt;/div&gt;"/>
    <Choice value="Head" hotkey="5"
            html="&lt;div style='background:#e0e7ff;padding:10px;border-radius:8px;border:2px solid #818cf8;margin:4px 0'&gt;&lt;b&gt;☁️ 5 头声 Head&lt;/b&gt;&lt;br/&gt;&lt;small&gt;头腔主导·非混合·古典/美声&lt;/small&gt;&lt;/div&gt;"/>
    <Choice value="Breathy" hotkey="6"
            html="&lt;div style='background:#fed7aa;padding:10px;border-radius:8px;border:2px solid #fb923c;margin:4px 0'&gt;&lt;b&gt;💨 6 漏气 Breathy&lt;/b&gt;&lt;br/&gt;&lt;small&gt;⚠️ 声门闭合不足·气息过多·尾音有气流声 | H1-H2大于8dB&lt;/small&gt;&lt;/div&gt;"/>
    <Choice value="Strained" hotkey="7"
            html="&lt;div style='background:#fecaca;padding:10px;border-radius:8px;border:2px solid #ef4444;margin:4px 0'&gt;&lt;b&gt;😣 7 挤卡 Strained&lt;/b&gt;&lt;br/&gt;&lt;small&gt;⚠️ 喉部过度紧张·紧硬卡住·颈部用力·可能破音 | 1-3kHz集中&lt;/small&gt;&lt;/div&gt;"/>
    <Choice value="Neutral" hotkey="0"
            html="&lt;div style='background:#f1f5f9;padding:10px;border-radius:8px;border:2px solid #94a3b8;margin:4px 0'&gt;&lt;b&gt;🔘 0 中性 Neutral&lt;/b&gt;&lt;br/&gt;&lt;small&gt;无明显特征·自然发声&lt;/small&gt;&lt;/div&gt;"/>
    <Choice value="Invalid" hotkey="x"
            html="&lt;div style='background:#fca5a5;padding:10px;border-radius:8px;border:2px solid #ef4444;margin:4px 0'&gt;&lt;b&gt;❌ X 无效 Invalid&lt;/b&gt;&lt;br/&gt;&lt;small&gt;噪音/说话/多人重叠/乐器残留&lt;/small&gt;&lt;/div&gt;"/>
  </Choices>

  <!-- 关键区分框 -->
  <View className="distinction-box">
    <Header value="⚡ 关键区分速查" size="5"/>
    <Text value="▸ Strained(主) vs Pharyngeal(辅): 挤卡=不稳·爆破·颈部用力·想咳嗽; 咽音=稳定·明亮·不紧张·可持续3秒+"/>
    <Text value="▸ StrongMix vs LightMix: 强混=同音高可提升响度·低频厚; 弱混=响度提不上去但连接顺·低频薄"/>
    <Text value="▸ LightMix vs Falsetto: 弱混=有支撑·谐波连续·可加力; 假声=完全轻飘·谐波稀疏·加力就破"/>
  </View>

  <!-- 第二部分：辅标签（共鸣/色彩，多选可选）-->
  <View className="section-secondary">
    🎨 第二步：标记共鸣技术与色彩（多选，可选）
  </View>
  <Text value="💡 辅标签=声道如何调整共鸣，可叠加在任何主标签上"/>

  <Header value="🔥 核心共鸣技术" style="color:#ec4899; font-size:14px; margin-top:12px;"/>
  <Choices name="secondary_tags" toName="audio" choice="multiple" showInline="false">
    <Choice value="Pharyngeal"
            html="&lt;div style='background:#fde68a;padding:10px;border-radius:6px;margin:4px 0'&gt;&lt;b&gt;✨ Pharyngeal 咽音&lt;/b&gt;&lt;br/&gt;&lt;small&gt;尖亮·前推·咽壁挂点 | 3-5kHz增强 | StrongMix+咽音=张杰式 | LightMix+咽音=华晨宇式&lt;/small&gt;&lt;/div&gt;"/>
    <Choice value="Twang"
            html="&lt;div style='background:#fcd34d;padding:10px;border-radius:6px;margin:4px 0'&gt;&lt;b&gt;🦆 Twang 收窄&lt;/b&gt;&lt;br/&gt;&lt;small&gt;鼻咽收窄·类似哭腔·穿透力强 | 2-4kHz增强&lt;/small&gt;&lt;/div&gt;"/>
    <Choice value="HighRange"
            html="&lt;div style='background:#c7d2fe;padding:8px 10px;border-radius:6px;margin:4px 0'&gt;&lt;b&gt;🎵 HighRange 高音区(C5+)&lt;/b&gt;&lt;/div&gt;"/>
    <Choice value="SuperHighRange"
            html="&lt;div style='background:#a5b4fc;padding:8px 10px;border-radius:6px;margin:4px 0'&gt;&lt;b&gt;🎵 SuperHighRange 超高音(C6+)&lt;/b&gt;&lt;/div&gt;"/>
    <Choice value="VowelMod"
            html="&lt;div style='background:#e9d5ff;padding:8px 10px;border-radius:6px;margin:4px 0'&gt;&lt;b&gt;🗣️ VowelMod 元音修改&lt;/b&gt;&lt;/div&gt;"/>
    <Choice value="Vibrato"
            html="&lt;div style='background:#fbcfe8;padding:8px 10px;border-radius:6px;margin:4px 0'&gt;&lt;b&gt;〰️ Vibrato 颤音&lt;/b&gt;&lt;/div&gt;"/>
    <Choice value="Glissando"
            html="&lt;div style='background:#d9f99d;padding:8px 10px;border-radius:6px;margin:4px 0'&gt;&lt;b&gt;↗️ Glissando 滑音&lt;/b&gt;&lt;/div&gt;"/>
    <Choice value="Runs"
            html="&lt;div style='background:#bae6fd;padding:8px 10px;border-radius:6px;margin:4px 0'&gt;&lt;b&gt;🎶 Runs 转音&lt;/b&gt;&lt;/div&gt;"/>
    <Choice value="Demo_Correct"
            html="&lt;div style='background:#d1fae5;padding:8px 10px;border-radius:6px;margin:4px 0'&gt;&lt;b&gt;✅ Demo_Correct 正确示范&lt;/b&gt;&lt;/div&gt;"/>
    <Choice value="Demo_Error"
            html="&lt;div style='background:#fee2e2;padding:8px 10px;border-radius:6px;margin:4px 0'&gt;&lt;b&gt;❌ Demo_Error 错误示范&lt;/b&gt;&lt;/div&gt;"/>
  </Choices>

  <!-- 第三部分：质量旗标 -->
  <View className="section-quality">
    🚩 第三步：标记质量问题（多选，可选）
  </View>
  <Choices name="quality_flags" toName="audio" choice="multiple" showInline="true">
    <Choice value="LowSNR" hotkey="ctrl+n" html="&lt;span style='color:red'&gt;🔊 LowSNR&lt;/span&gt;"/>
    <Choice value="HighReverb" hotkey="ctrl+r" html="&lt;span style='color:orange'&gt;🏛 HighReverb&lt;/span&gt;"/>
    <Choice value="Clipping" html="&lt;span style='color:red'&gt;📢 Clipping&lt;/span&gt;"/>
    <Choice value="Unstable" html="&lt;span style='color:purple'&gt;〰️ Unstable&lt;/span&gt;"/>
    <Choice value="MultiVoice" html="&lt;span style='color:blue'&gt;👥 MultiVoice&lt;/span&gt;"/>
    <Choice value="Distortion" html="&lt;span style='color:brown'&gt;⚡ Distortion&lt;/span&gt;"/>
  </Choices>

  <!-- 备注 & 置信度 -->
  <Header value="📝 备注（可选）" style="margin-top:20px; color:#475569;"/>
  <TextArea name="annotator_notes" toName="audio"
            placeholder="特殊情况说明，如：StrongMix但C6以上有挤卡倾向；咽音在副歌最明显"
            rows="2" maxSubmissions="1"/>
  <Header value="⭐ 标注置信度" size="5" style="margin-top:12px;"/>
  <Rating name="confidence_rating" toName="audio" maxRating="5" defaultValue="3"/>

  <!-- 快捷键 -->
  <View className="hotkey-guide">
    <Text value="⌨️ 1强混 2弱混 3假声 4胸声 5头声 6漏气 7挤卡 0中性 X无效 | Space播放 | Ctrl+N/R质量旗标"/>
  </View>

  <View style="background:#f8fafc; padding:12px; margin-top:16px; border-radius:8px; border:1px solid #e2e8f0;">
    <Text name="source_info" value="$source_name" style="font-size:12px; color:#64748b;"/>
  </View>
</View>
